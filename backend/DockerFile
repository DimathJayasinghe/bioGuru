# ==========================================
# Stage 1: Build the TypeScript code
# ==========================================
FROM node:20-alpine AS builder

WORKDIR /app

# Copy package files first to cache dependencies
COPY package*.json ./
COPY prisma ./prisma/

# Install ALL dependencies (including devDependencies like TypeScript)
RUN npm install

# Generate Prisma Client
RUN npx prisma generate

# Copy the rest of the source code
COPY . .

# Compile TypeScript to JavaScript (creates the /dist folder)
RUN npm run build

# ==========================================
# Stage 2: Production Server
# ==========================================
FROM node:20-alpine AS production

WORKDIR /app

# Set Node to production mode (makes Express faster)
ENV NODE_ENV=production

# Copy package files
COPY package*.json ./
COPY prisma ./prisma/

# Install ONLY production dependencies (skips heavy TS compilers)
RUN npm install --only=production
RUN npx prisma generate

# Copy the compiled JavaScript from the Builder stage
COPY --from=builder /app/dist ./dist

# Expose the API port
EXPOSE 8080

# Start the server using the compiled JavaScript
CMD ["node", "dist/index.js"]